# Copy to `.env` in this directory (gitignored). Load before `npm run server`, e.g.:
#   set -a && source .env && set +a && npm run server
# Or use your shell / IDE env injection.
#
# Google Cloud Console: enable "Places API (New)" and create an API key restricted to that API.
GOOGLE_MAPS_API_KEY=

# Optional: proxy listen port (default 8787)
# PORT=8787

# Optional: browser origin if you call the proxy without Vite's dev/preview proxy
# CORS_ORIGIN=http://127.0.0.1:4173

# Optional: override Vite proxy target (default http://127.0.0.1:8787)
# VITE_PLACES_PROXY=http://127.0.0.1:8787
